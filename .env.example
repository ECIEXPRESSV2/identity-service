# Base de datos 
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/identity_db

#  Firebase Admin SDK 
FIREBASE_PROJECT_ID=tu-proyecto-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto-xxxxx.iam.gserviceaccount.com

FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...(tu clave)...\n-----END PRIVATE KEY-----\n"

# RabbitMQ 
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=eciexpress_events

# App
PORT=3001
NODE_ENV=development
SERVICE_NAME=identity-service

# Azure Blob Storage (ESCRITURA): cadena de conexión de la cuenta de storage.
# Solo backend: sube los logos de tienda a store-logos/<storeId>.png. Contiene el AccountKey,
# así que NUNCA debe ir al frontend. Azure Portal → Storage account → Access keys.
AZURE_STORAGE_CONNECTION_STRING=
# STORE_LOGOS_CONTAINER=store-logos  # opcional; por defecto "store-logos"

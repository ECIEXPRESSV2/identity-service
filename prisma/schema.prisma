generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SystemRole {
  BUYER
  VENDOR
  ADMIN
  ANALYST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StoreType {
  CAFETERIA
  PAPELERIA
  RESTAURANTE
}

enum StoreStatus {
  OPEN
  CLOSED
  TEMPORARILY_CLOSED
}

enum ClosureStatus {
  SCHEDULED
  ACTIVE
  EXPIRED
  CANCELLED
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum PqrsStatus {
  OPEN
  CLOSED
}

enum PqrsSenderRole {
  USER
  ADMIN
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  ROLE_ASSIGNED
  ROLE_REVOKED
  STORE_CREATED
  STORE_UPDATED
  STORE_CLOSURE_CREATED
  STORE_CLOSURE_CANCELLED
  STORE_STAFF_ASSIGNED
  STORE_STAFF_REMOVED
  PERMISSION_GRANTED
  PERMISSION_REVOKED
}

// ─── Identity Domain ──────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  firebaseUid   String     @unique
  email         String     @unique
  fullName      String
  phone         String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userRoles    UserRole[]
  ownedStores  Store[]        @relation("StoreOwner")
  auditLogs    AuditLog[]     @relation("ActorLogs")
  closures     StoreClosure[] @relation("ClosureCreator")
  staffEntries StoreStaff[]   @relation("StaffMember")
  sessions     UserSession[]
  pqrsTickets  Pqrs[]         @relation("PqrsOwner")

  @@map("users")
}

model Role {
  id          String      @id @default(uuid())
  name        String      @unique
  systemRole  SystemRole?
  isSystem    Boolean     @default(false)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime  @default(now())
  assignedBy String?
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Administration Domain ────────────────────────────────────────────────────

model Store {
  id          String      @id @default(uuid())
  ownerId     String
  name        String      @unique
  type        StoreType
  description String?
  location    String
  imageUrl    String?
  bannerUrl   String?
  status      StoreStatus @default(OPEN)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  owner     User            @relation("StoreOwner", fields: [ownerId], references: [id])
  schedules StoreSchedule[]
  closures  StoreClosure[]
  staff     StoreStaff[]

  @@map("stores")
}

model StoreStaff {
  id         String    @id @default(uuid())
  storeId    String
  userId     String
  assignedBy String?
  assignedAt DateTime  @default(now())
  isActive   Boolean   @default(true)
  removedBy  String?
  removedAt  DateTime?

  store Store @relation(fields: [storeId], references: [id])
  user  User  @relation("StaffMember", fields: [userId], references: [id])

  @@unique([storeId, userId])
  @@map("store_staff")
}

model StoreSchedule {
  id        String   @id @default(uuid())
  storeId   String
  dayOfWeek Int
  openTime  String
  closeTime String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, dayOfWeek])
  @@map("store_schedules")
}

model StoreClosure {
  id          String        @id @default(uuid())
  storeId     String
  startDate   DateTime
  endDate     DateTime
  reason      String?       @db.VarChar(200)
  status      ClosureStatus @default(SCHEDULED)
  createdBy   String
  cancelledBy String?
  cancelledAt DateTime?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store   Store @relation(fields: [storeId], references: [id])
  creator User  @relation("ClosureCreator", fields: [createdBy], references: [id])

  @@map("store_closures")
}

// ─── Transversal ──────────────────────────────────────────────────────────────

model OutboxEvent {
  id             String       @id @default(uuid())
  aggregateId    String
  aggregateType  String
  eventType      String
  eventVersion   Int          @default(1)
  payload        Json
  status         OutboxStatus @default(PENDING)
  retryCount     Int          @default(0)
  lastError      String?
  nextRetryAt    DateTime?
  idempotencyKey String       @unique
  createdAt      DateTime     @default(now())
  publishedAt    DateTime?

  @@map("outbox_events")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  targetId   String
  targetType String
  action     AuditAction
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  actor User? @relation("ActorLogs", fields: [actorId], references: [id])

  @@map("audit_logs")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  sessionId String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model Pqrs {
  id        String     @id @default(uuid())
  userId    String
  subject   String
  status    PqrsStatus @default(OPEN)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  closedAt  DateTime?
  closedBy  String?

  user     User          @relation("PqrsOwner", fields: [userId], references: [id])
  messages PqrsMessage[]

  @@map("pqrs")
}

model PqrsMessage {
  id         String         @id @default(uuid())
  pqrsId     String
  senderId   String
  senderRole PqrsSenderRole
  body       String
  createdAt  DateTime       @default(now())

  pqrs Pqrs @relation(fields: [pqrsId], references: [id])

  @@map("pqrs_messages")
}
